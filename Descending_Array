#include<iostream>
using namespace std;
int main() {
    int n;
    cin>>n;
    int arr[n];
    for (int i=0;i<n;i++) {
        cin>>arr[i];
    }
    int a[n];
    for (int i=0;i<n;i++) {
        int p=arr[0];
        int j=0;
        for (int k=0;k<n;k++) {
            if (p<arr[k]) {
                p=arr[k];
                j=k;
            }
        }
        arr[j]='\0';
        a[i]=p;

    }
    for (int i=0;i<n;i++) {
        cout<<a[i]<<endl;
    }
}
