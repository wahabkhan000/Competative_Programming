#include<iostream>
#include<string>
using namespace std;
int main() {
    string s;
    cin>>s;
    unsigned int b=s.length();
    string a;
    int count=0;
    for (int i=0;i<b;i++) {
        if (s[i] != '-' && s[i] != '_') {
            a+=s[i];
            count++;
        }
        else if (s[i] == '-' || s[i] == '_'){
            int c=i+1;
            if (s[c]>='a'&&s[c]<='z') {
                s[c]-=32;
                s[i]=s[c];
                a+=s[i];
                i++;
            }
        }
    }
    cout<<a;
}
